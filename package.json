    "dependencies": {
        "@astrojs/mdx": "^7.0.0",
        "@astrojs/rss": "^4.0.19",
        "@astrojs/sitemap": "^3.7.3",
        "@fontsource-variable/inter": "^5.2.8",
        "@fontsource-variable/newsreader": "^5.2.10",
        "@tailwindcss/vite": "^4.3.2",
        "astro": "^7.0.4",
        "marked": "^18.0.5",
        "tailwindcss": "^4.3.2"
    },
    "devDependencies": {
        "@tailwindcss/typography": "^0.5.20",
        "prettier": "^3.9.4",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "wrangler": "^4.106.0"
    }
