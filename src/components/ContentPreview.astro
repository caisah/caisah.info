---
import { type CollectionEntry } from 'astro:content';
import ArrowRight from '../icons/ArrowRight.astro';
import FormattedDate from './FormattedDate.astro';

type SupportedEntry = CollectionEntry<'blog'> | CollectionEntry<'notes'>;
type Props = {
    entry: SupportedEntry;
    basePath: '/blog' | '/notes';
    class?: string;
    headingLevel?: 'h2' | 'h3';
    actionLabel?: string;
};

const { entry, basePath, class: className, headingLevel = 'h2', actionLabel } = Astro.props;
const { title, publishDate, updatedDate } = entry.data;
const excerpt = 'excerpt' in entry.data ? entry.data.excerpt : undefined;
const TitleTag = headingLevel;
const label = actionLabel ?? (basePath === '/blog' ? 'Read Post' : 'Read Note');
---

<a class:list={['flex justify-between items-start gap-8 group', className]} href={`${basePath}/${entry.id}/`}>
    <div class="grow">
        <TitleTag
            class="text-xl leading-tight font-serif font-medium group-hover:underline group-hover:decoration-dashed group-hover:underline-offset-4 group-hover:decoration-1 sm:text-2xl"
        >
            {title}
        </TitleTag>
        <div class="mt-1 text-sm leading-normal">
            <FormattedDate date={publishDate} />
            {
                updatedDate && (
                    <>
                        {' '}
                        <span>
                            (Updated on <FormattedDate date={updatedDate} />)
                        </span>
                    </>
                )
            }
        </div>
        {excerpt && <div class="mt-3 text-sm leading-normal">{excerpt}</div>}
    </div>
    <div class="hidden font-serif italic opacity-0 transition group-hover:opacity-100 sm:inline-flex sm:gap-1 sm:items-center sm:shrink-0">
        {label} <ArrowRight class="fill-current w-4 h-4" />
    </div>
</a>
