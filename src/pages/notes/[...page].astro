---
import type { GetStaticPathsOptions, Page } from 'astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Pagination from '../../components/Pagination.astro';
import ContentPreview from '../../components/ContentPreview.astro';
import siteConfig from '../../data/site-config';
import { sortItemsByDateDesc } from '../../utils/data-utils';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const notes = (await getCollection('notes')).sort(sortItemsByDateDesc);

  return paginate(notes, { pageSize: siteConfig.postsPerPage || 4 });
}

type Props = { page: Page<CollectionEntry<'notes'>> };

const { page } = Astro.props;
const allNotes = page.data;
---

<BaseLayout
    title="Notes"
    description="Short notes and updates"
    image={{ src: '/dante-preview.jpg', alt: 'The preview of the site' }}
    showHeader={false}
>
    <h1 class="mb-12 text-2xl leading-tight font-serif italic sm:mb-16 sm:text-4xl">Notes Archive</h1>
     {allNotes.map((note) => <ContentPreview entry={note} basePath="/notes" class="mb-10 sm:mb-12" actionLabel="Read Note" />)}
    <Pagination page={page} class="my-16 sm:my-24" />

</BaseLayout>
